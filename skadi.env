# =====================================================
# SKADI ELK Stack – Environment Configuration
# =====================================================

# Elastic stack version (must match across all services)
ELASTIC_VERSION=8.13.4

# Credentials
ELASTIC_PASSWORD=Y2K_passwd
KIBANA_PASSWORD=Y2K_passwd

# Ports exposed on the host
ES_PORT=9200
KIBANA_PORT=5601

# JVM heap for Elasticsearch (keep under half of available RAM)
ES_HEAP=1g
